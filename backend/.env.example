PORT=5000
NODE_ENV=production
MONGO_URI=mongodb://127.0.0.1:27017/face_attendance
JWT_SECRET=replace_with_a_long_random_secret_of_at_least_32_characters
JWT_EXPIRES_IN=12h
CORS_ORIGINS=http://localhost:3000
ALLOW_DEFAULT_ADMIN=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_me_before_use
FACE_SERVICE_URL=http://127.0.0.1:8000
FACE_REQUEST_TIMEOUT_MS=15000
FACE_MAX_BASE64_LENGTH=3000000
MAX_EXCEL_UPLOAD_BYTES=5242880
MAX_IMAGE_UPLOAD_BYTES=3145728
MAX_DOCUMENT_UPLOAD_BYTES=8388608
MAIL_USER=your_email@example.com
MAIL_PASS=your_app_password
PROVISION_ADMIN_USERNAME=admin
PROVISION_ADMIN_PASSWORD=change_me_before_use
PROVISION_ADMIN_NAME=Institute Admin
